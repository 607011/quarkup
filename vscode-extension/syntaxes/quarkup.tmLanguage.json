    "code-block-lang-cpp": {
      "begin": "^(\\.s+)[ \\t]+(cpp|c\\+\\+)[ \\t]*$",
      "beginCaptures": { "1": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" }, "2": { "name": "entity.name.tag.language.quarkup" } },
      "end": "^[ \\t]*(?!\\\\\\.\\.)\\.\\..*$",
      "endCaptures": { "0": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" } },
      "name": "markup.raw.block.quarkup",
      "contentName": "meta.embedded.block.cpp",
      "patterns": [{ "include": "source.cpp" }]
    },
    "code-block-lang-go": {
      "begin": "^(\\.s+)[ \\t]+(go|golang)[ \\t]*$",
