      "endCaptures": { "0": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" } },
      "name": "markup.raw.block.quarkup",
      "contentName": "meta.embedded.block.toml",
      "patterns": [{ "include": "source.toml" }]
    },

    "code-block-generic": {
      "begin": "^(\\.s+)[ \\t]+(\\S+)[ \\t]*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" },
        "2": { "name": "entity.name.tag.language.quarkup" }
      },
      "end": "^[ \\t]*(?!\\\\\\.\\.)\\.\\..*$",
      "endCaptures": {
        "0": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" }
      },
      "name": "markup.raw.block.quarkup"
    },

    "lattice-block": {
      "begin": "^(\\.l)[ \\t]*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.table.quarkup entity.name.tag.quarkup" }
      },
      "end": "^[ \\t]*\\.\\..*$",
      "endCaptures": {
        "0": { "name": "keyword.control.table.quarkup entity.name.tag.quarkup" }
      },
      "name": "meta.table.quarkup",
      "patterns": [
        {
          "match": "^(h:|f:|s:)",
          "name": "keyword.other.rowtype.quarkup keyword.control.quarkup entity.name.tag.quarkup"
        },
        {
          "match": ";",
          "name": "punctuation.separator.cell.quarkup"
        },
        {
          "match": "(?<=;|^)[ \\t]*(>)[ \\t]*(?=;|$)",
          "name": "keyword.operator.colspan.quarkup entity.name.tag.quarkup"
        },
        {
          "match": "(?<=;|^)[ \\t]*(_)[ \\t]*(?=;|$)",
          "name": "keyword.operator.rowspan.quarkup entity.name.tag.quarkup"
        },
        {
          "match": "(\\.\\^|\\.>)[ \\t]",
          "name": "keyword.operator.alignment.quarkup entity.name.tag.quarkup"
        },
        { "include": "#inline" }
      ]
    },

    "conditional-block": {
      "begin": "^(\\.b)[ \\t]+(!)?(.+)$",
      "beginCaptures": {
        "1": { "name": "keyword.control.conditional.quarkup entity.name.tag.quarkup" },
        "2": { "name": "keyword.operator.negation.quarkup" },
        "3": { "name": "variable.parameter.condition.quarkup" }
      },
      "end": "^[ \\t]*\\.\\..*$",
      "endCaptures": {
        "0": { "name": "keyword.control.conditional.quarkup entity.name.tag.quarkup" }
      },
      "name": "meta.conditional.quarkup",
      "patterns": [{ "include": "$self" }]
    },

    "heading-1": {
      "match": "^(\\.u)(?!u)[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "keyword.control.heading.quarkup entity.name.tag.quarkup" },
        "2": { "name": "markup.heading.1.quarkup", "patterns": [{ "include": "#inline" }] }
      }
    },
    "heading-2": {
      "match": "^(\\.uu)(?!u)[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "keyword.control.heading.quarkup entity.name.tag.quarkup" },
        "2": { "name": "markup.heading.2.quarkup", "patterns": [{ "include": "#inline" }] }
      }
    },
    "heading-3": {
      "match": "^(\\.uuu)(?!u)[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "keyword.control.heading.quarkup entity.name.tag.quarkup" },
        "2": { "name": "markup.heading.3.quarkup", "patterns": [{ "include": "#inline" }] }
      }
    },
    "heading-4": {
      "match": "^(\\.uuuu)(?!u)[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "keyword.control.heading.quarkup entity.name.tag.quarkup" },
        "2": { "name": "markup.heading.4.quarkup", "patterns": [{ "include": "#inline" }] }
      }
    },
    "heading-5": {
      "match": "^(\\.uuuuu)(?!u)[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "keyword.control.heading.quarkup entity.name.tag.quarkup" },
        "2": { "name": "markup.heading.5.quarkup", "patterns": [{ "include": "#inline" }] }
      }
    },
    "heading-6": {
      "match": "^(\\.u{6,})[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "keyword.control.heading.quarkup entity.name.tag.quarkup" },
        "2": { "name": "markup.heading.6.quarkup", "patterns": [{ "include": "#inline" }] }
      }
    },

    "metadata": {
      "match": "^(\\.t)[ \\t]+(\\S+)(?:[ \\t]+(.*))?$",
      "captures": {
        "1": { "name": "keyword.control.metadata.quarkup entity.name.tag.quarkup" },
        "2": { "name": "variable.other.property.quarkup" },
        "3": { "name": "string.unquoted.quarkup" }
      }
    },

    "image": {
      "match": "^(\\.g)[ \\t]+(\\S+)(?:[ \\t]+(.*))?$",
      "captures": {
        "1": { "name": "keyword.other.image.quarkup keyword.control.quarkup entity.name.tag.quarkup" },
        "2": { "name": "string.other.link.quarkup" },
        "3": { "name": "string.unquoted.quarkup", "patterns": [{ "include": "#inline" }] }
      }
    },

    "list-unordered": {
      "match": "^(\\.n+)[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.list.quarkup keyword.control.quarkup entity.name.tag.quarkup" },
        "2": { "patterns": [{ "include": "#inline" }] }
      }
    },
    "list-ordered": {
      "match": "^(\\.e+)[ \\t]+(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.list.quarkup keyword.control.quarkup entity.name.tag.quarkup" },
        "2": { "patterns": [{ "include": "#inline" }] }
      }
    },

    "inline": {
      "patterns": [
        { "include": "#inline-math" },
        { "include": "#inline-code" },
        { "include": "#inline-bold" },
        { "include": "#inline-italic" },
        { "include": "#inline-superscript" },
        { "include": "#inline-subscript" },
        { "include": "#inline-link" },
        { "include": "#inline-conditional" }
      ]
    },
    "inline-math": {
      "begin": "(\\.s+)[ \\t](math)[ \\t]",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.code.quarkup keyword.control.quarkup entity.name.tag.quarkup" },
        "2": { "name": "entity.name.tag.language.quarkup" }
      },
      "end": "\\.\\.",
      "endCaptures": { "0": { "name": "punctuation.definition.code.quarkup keyword.control.quarkup entity.name.tag.quarkup" } },
      "name": "string.other.math.inline.quarkup"
    },
    "inline-code": {
      "begin": "(\\.s+)[ \\t]",
      "beginCaptures": { "1": { "name": "punctuation.definition.code.quarkup keyword.control.quarkup entity.name.tag.quarkup" } },
      "end": "\\.\\.",
      "endCaptures": { "0": { "name": "punctuation.definition.code.quarkup keyword.control.quarkup entity.name.tag.quarkup" } },
      "name": "markup.inline.raw.quarkup"
    },
    "inline-bold": {
      "begin": "(\\.m+)[ \\t]",
      "beginCaptures": { "1": { "name": "punctuation.definition.bold.quarkup keyword.control.quarkup entity.name.tag.quarkup" } },
      "end": "\\.\\.",
      "endCaptures": { "0": { "name": "punctuation.definition.bold.quarkup keyword.control.quarkup entity.name.tag.quarkup" } },
      "name": "markup.bold.quarkup",
      "patterns": [{ "include": "#inline" }]
    },
    "inline-italic": {
      "begin": "(\\.c+)[ \\t]",
      "beginCaptures": { "1": { "name": "punctuation.definition.italic.quarkup keyword.control.quarkup entity.name.tag.quarkup" } },
      "end": "\\.\\.",
      "endCaptures": { "0": { "name": "punctuation.definition.italic.quarkup keyword.control.quarkup entity.name.tag.quarkup" } },
      "name": "markup.italic.quarkup",
      "patterns": [{ "include": "#inline" }]
    },
    "inline-superscript": {
      "begin": "(\\.u+)[ \\t]",
