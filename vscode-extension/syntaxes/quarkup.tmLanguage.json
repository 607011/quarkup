{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Quarkup",
  "scopeName": "source.quarkup",
  "patterns": [
    { "include": "#comment" },
    { "include": "#code-block-bare" },
    { "include": "#code-block-math" },
    { "include": "#code-block-known-languages" },
    { "include": "#code-block-generic" },
    { "include": "#lattice-block" },
    { "include": "#conditional-block" },
    { "include": "#heading-1" },
    { "include": "#heading-2" },
    { "include": "#heading-3" },
    { "include": "#heading-4" },
    { "include": "#heading-5" },
    { "include": "#heading-6" },
    { "include": "#metadata" },
    { "include": "#image" },
    { "include": "#list-unordered" },
    { "include": "#list-ordered" },
    { "include": "#inline" }
  ],
  "repository": {
    "comment": {
      "match": "^[ \\t]*(#|//).*$",
      "name": "comment.line.quarkup"
    },

    "code-block-bare": {
      "begin": "^(\\.s+)[ \\t]*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" }
      },
      "end": "^[ \\t]*(?!\\\\\\.\\.)\\.\\..*$",
      "endCaptures": {
        "0": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" }
      },
      "name": "markup.raw.block.quarkup"
    },

    "code-block-math": {
      "begin": "^(\\.s+)[ \\t]+(math)[ \\t]*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" },
        "2": { "name": "entity.name.tag.language.quarkup" }
      },
      "end": "^[ \\t]*(?!\\\\\\.\\.)\\.\\..*$",
      "endCaptures": {
        "0": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" }
      },
      "name": "string.other.math.block.quarkup"
    },

    "code-block-known-languages": {
      "patterns": [
        { "include": "#code-block-lang-rust" },
        { "include": "#code-block-lang-js" },
        { "include": "#code-block-lang-ts" },
        { "include": "#code-block-lang-json" },
        { "include": "#code-block-lang-python" },
        { "include": "#code-block-lang-html" },
        { "include": "#code-block-lang-css" },
        { "include": "#code-block-lang-c" },
        { "include": "#code-block-lang-cpp" },
        { "include": "#code-block-lang-go" },
        { "include": "#code-block-lang-ruby" },
        { "include": "#code-block-lang-yaml" },
        { "include": "#code-block-lang-shell" },
        { "include": "#code-block-lang-sql" },
        { "include": "#code-block-lang-markdown" },
        { "include": "#code-block-lang-xml" },
        { "include": "#code-block-lang-java" },
        { "include": "#code-block-lang-csharp" },
        { "include": "#code-block-lang-php" },
        { "include": "#code-block-lang-toml" }
      ]
    },
    "code-block-lang-rust": {
      "begin": "^(\\.s+)[ \\t]+(rust|rs)[ \\t]*$",
      "beginCaptures": { "1": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" }, "2": { "name": "entity.name.tag.language.quarkup" } },
      "end": "^[ \\t]*(?!\\\\\\.\\.)\\.\\..*$",
      "endCaptures": { "0": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" } },
      "name": "markup.raw.block.quarkup",
      "contentName": "meta.embedded.block.rust",
      "patterns": [{ "include": "source.rust" }]
    },
    "code-block-lang-js": {
      "begin": "^(\\.s+)[ \\t]+(js|javascript)[ \\t]*$",
      "beginCaptures": { "1": { "name": "keyword.control.codeblock.quarkup entity.name.tag.quarkup" }, "2": { "name": "entity.name.tag.language.quarkup" } },
